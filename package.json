{
  "name": "codediag",
  "version": "0.2.0",
  "description": "Automated project health scanner for Node.js, NestJS, Express, and Next.js projects.",
  "author": "Sabahattin Kalkan <hello@sabahattinkalkan.com> (https://sabahattinkalkan.com)",
  "license": "MIT",
  "type": "module",
  "bin": {
    "codediag": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "schema"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/index.js",
    "lint": "biome lint src tests tests-cli",
    "format": "biome format --write src tests tests-cli",
    "format:check": "biome format src tests tests-cli",
    "test": "tsx --test tests/*.test.ts",
    "test:cli": "node --test tests-cli/*.test.mjs",
    "check": "npm run lint && npm run format:check && npm run typecheck && npm test && npm run build && npm run test:cli",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run check"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sabahattink/codediag.git"
  },
  "homepage": "https://sabahattink.github.io/codediag/",
  "bugs": {
    "url": "https://github.com/sabahattink/codediag/issues"
  },
  "keywords": [
    "code-quality",
    "diagnostics",
    "nestjs",
    "nextjs",
    "express",
    "security",
    "audit",
    "cli",
    "health-check",
    "static-analysis",
    "devtools",
    "testing"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "glob": "^13.0.6",
    "ora": "^8.1.0",
    "ts-morph": "^24.0.0",
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@types/node": "^22.0.0",
    "ajv": "^8.20.0",
    "tsup": "^8.3.0",
    "tsx": "^4.20.6",
    "typescript": "^7.0.2"
  }
}
